import pytesseract
from pdf2image import convert_from_path
import cv2
import numpy as np
from PIL import Image
import pandas as pd

PDF_PATH = "C:\Users\leonardopinheiro\Desktop\601-744.pdf"

# Windows (se necessário):
# pytesseract.pytesseract.tesseract_cmd = r"C:\Program Files\Tesseract-OCR\tesseract.exe"


def preprocessar(imagem_pil):
    """Melhora imagem para OCR pesado"""

    img = np.array(imagem_pil)

    # escala de cinza
    gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY)

    # remover ruído
    blur = cv2.GaussianBlur(gray, (5,5), 0)

    # threshold adaptativo (melhor p/ fundo cinza)
    thresh = cv2.adaptiveThreshold(
        blur, 255,
        cv2.ADAPTIVE_THRESH_GAUSSIAN_C,
        cv2.THRESH_BINARY,
        31, 2
    )

    # aumentar contraste
    kernel = np.ones((1,1), np.uint8)
    img = cv2.dilate(thresh, kernel, 1)
    img = cv2.erode(img, kernel, 1)

    return img


print("Convertendo PDF em imagens...")
pages = convert_from_path(PDF_PATH, dpi=400)

texto_total = []
linhas_csv = []

for i, page in enumerate(pages):

    print(f"OCR página {i+1}")

    img = preprocessar(page)

    # Config melhor para tabelas
    config = r'--oem 3 --psm 6 -l por'

    texto = pytesseract.image_to_string(
        img,
        config=config
    )

    texto_total.append(texto)

    # tentativa de estruturar tabela
    for linha in texto.split("\n"):
        if linha.strip():
            linhas_csv.append(linha.split())


# salvar TXT completo
with open("OCR_COMPLETO.txt", "w", encoding="utf-8") as f:
    f.write("\n\n".join(texto_total))


# salvar CSV preliminar
df = pd.DataFrame(linhas_csv)
df.to_csv("OCR_TABELA.csv", index=False, sep=";")


print("✔ OCR finalizado")
print("Arquivos gerados:")
print("- OCR_COMPLETO.txt")
print("- OCR_TABELA.csv")
